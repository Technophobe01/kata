/.kata/
/.kata-*/
**/credentials.toml
*.db
*.db-*
*.sqlite
*.sqlite-*
*.sqlite3
*.sqlite3-*

# Repo-local work/agent/editor state.
/.worktrees/
/.superpowers/
/.codex/
/.superset/
/.claude/settings.local.json
.vscode/
.idea/
*.swp
*~
.DS_Store
.kata.local.toml
